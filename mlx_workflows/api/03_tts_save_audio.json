{
  "1": {
    "class_type": "CLIPLoader",
    "inputs": {
      "clip_name": "soprano_80m_mlx_audio_tts.mlx.json",
      "type": "mlx_audio_tts",
      "device": "default"
    }
  },
  "2": {
    "class_type": "TextGenerate",
